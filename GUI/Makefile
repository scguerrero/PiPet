		../Pet/piPet.h \
		care_class/affection.h \
		care_class/feed.h \
		care_class/sleep.h \
		train_class/train.h \
		battle_class/battle.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cc

